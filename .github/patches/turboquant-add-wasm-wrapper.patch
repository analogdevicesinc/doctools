diff --git a/turboquant/build.zig b/turboquant/build.zig
index ecb2ebb..32c31d3 100644
--- a/turboquant/build.zig
+++ b/turboquant/build.zig
@@ -55,4 +55,32 @@ pub fn build(b: *std.Build) void {
 
     const bench_step = b.step("bench", "Run benchmarks");
     bench_step.dependOn(&bench_run.step);
+
+    // -- WASM build (relaxed SIMD) --
+    const wasm_target = b.resolveTargetQuery(.{
+        .cpu_arch = .wasm32,
+        .os_tag = .wasi,
+        .cpu_features_add = std.Target.wasm.featureSet(&.{ .simd128, .relaxed_simd }),
+    });
+
+    const wasm_mod = b.createModule(.{
+        .root_source_file = b.path("src/wasm_exports.zig"),
+        .target = wasm_target,
+        .optimize = .ReleaseFast,
+    });
+
+    const wasm_lib = b.addExecutable(.{
+        .name = "turboquant",
+        .root_module = wasm_mod,
+    });
+    wasm_lib.entry = .disabled;
+    wasm_lib.rdynamic = true;
+    wasm_lib.root_module.strip = true;
+
+    const install_wasm = b.addInstallArtifact(wasm_lib, .{
+        .dest_dir = .{ .override = .{ .custom = "../dist" } },
+    });
+
+    const wasm_step = b.step("wasm", "Build WASM module");
+    wasm_step.dependOn(&install_wasm.step);
 }
